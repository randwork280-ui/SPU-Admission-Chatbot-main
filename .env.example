OPENAI_API_KEY=your_openai_api_key_here

# Recommended default: low cost, strong quality for RAG admissions Q&A.
OPENAI_MODEL=gpt-4.1-mini

# Higher quality, higher cost option:
# OPENAI_MODEL=gpt-4.1

# Frontend origins allowed to call backend APIs.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Admin authentication.
# Generate ADMIN_PASSWORD_HASH with:
# python -c "from Services.Data_Loader.admin_security import hash_password; print(hash_password('replace-this-password'))"
ADMIN_PASSWORD_HASH=pbkdf2_sha256$replace_salt_hex$replace_digest_hex
ADMIN_TOKEN_SECRET=replace-with-a-long-random-secret-at-least-32-chars
ADMIN_TOKEN_TTL_SECONDS=3600

# Retrieval/vector configuration.
QDRANT_COLLECTION_NAME=arabic_university_docs
MIN_RELEVANCE_SCORE=0.3
MAX_RETRIEVAL_K=12
RATE_LIMIT_PER_MINUTE=30

# Cache strategy.
# OpenAI prompt caching is automatic on supported models for long, repeated prefixes.
# The prompt cache key keeps this app's traffic routed consistently.
PROMPT_VERSION=admissions-rag-v1
ANSWER_POLICY_VERSION=admissions-answer-v1
OPENAI_PROMPT_CACHE_KEY_PREFIX=spu-admissions
# Optional. Leave empty unless you intentionally choose an OpenAI-supported retention mode.
OPENAI_PROMPT_CACHE_RETENTION=

# Local application caches. Set CACHE_ENABLED=false or CACHE_BACKEND=off to disable.
CACHE_ENABLED=true
CACHE_BACKEND=memory
CACHE_NAMESPACE=spu-admissions
CACHE_MAX_ENTRIES=2048
RETRIEVAL_CACHE_TTL_SECONDS=1800
RETRIEVAL_EMPTY_CACHE_TTL_SECONDS=60
ANSWER_CACHE_ENABLED=true
ANSWER_CACHE_TTL_SECONDS=21600
ANSWER_CACHE_MIN_CONFIDENCE=0.45
COLLECTION_VERSION_TTL_SECONDS=15

# Embedding-store query-vector cache.
QUERY_EMBEDDING_CACHE_ENABLED=true
QUERY_EMBEDDING_CACHE_TTL_SECONDS=3600
QUERY_EMBEDDING_CACHE_MAX_ENTRIES=4096

# Optional cost telemetry. Fill with your active model prices per 1M tokens.
MODEL_INPUT_PRICE_PER_1M=0
MODEL_CACHED_INPUT_PRICE_PER_1M=0
MODEL_OUTPUT_PRICE_PER_1M=0
